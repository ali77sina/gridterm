# Copy this file to `.env` and fill in your Azure OpenAI details.
# `.env` is gitignored and never committed.

# Your Azure OpenAI resource endpoint, e.g. https://my-resource.openai.azure.com
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com

# The deployment name of your chat model (NOT the model name).
AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# API version (optional; defaults to 2024-10-21).
AZURE_OPENAI_API_VERSION=2024-10-21

# Your Azure OpenAI API key.
AZURE_OPENAI_KEY=your-api-key-here
